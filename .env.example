APP_ENV=local
LOG_LEVEL=INFO
TZ=Europe/Rome
POSTGRES_DB=energy_monitor
POSTGRES_USER=energy_user
POSTGRES_PASSWORD=energy_pass
DATABASE_URL=postgresql+psycopg://energy_user:energy_pass@postgres:5432/energy_monitor
FORECAST_SERVICE_URL=http://forecast-service:8001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MONGO_ENABLED=true
MONGO_URL=mongodb://mongo:27017
MONGO_DATABASE=energy_monitor
MONGO_ACTION_COLLECTION=user_action_events
VITE_API_BASE_URL=http://localhost:8000
VITE_FORECAST_API_BASE_URL=http://localhost:8001
